generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WorkType {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  defaultUnit String      @map("default_unit")
  workEntries WorkEntry[]

  @@map("work_types")
}

model WorkEntry {
  id           Int      @id @default(autoincrement())
  performedAt  DateTime @map("performed_at") @db.Date
  workTypeId   Int      @map("work_type_id")
  workType     WorkType @relation(fields: [workTypeId], references: [id], onDelete: Restrict)
  volume       Decimal  @db.Decimal(12, 2)
  unit         String
  executorName String   @map("executor_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([performedAt])
  @@map("work_entries")
}
